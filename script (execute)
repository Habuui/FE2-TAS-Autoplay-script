        if err_count > 0 then msg = msg .. " (" .. err_count .. " erro(s))" end
        showNotif(msg, ok_count > 0, 5)
        print("[FE2 TAS v15.9 FIXED 7] Download concluído: " .. ok_count .. " OK, " .. err_count .. " erros.")
    end)
end

-- ============================================================
-- ========== DETECTOR V17.0 — MOTOR CORRIGIDO (CORREÇÃO 2) ==
-- isTrulyVisible: sobe toda a hierarquia checando visibilidade.
-- obterScreenGuiDoLoadingAtivo: isola a ScreenGui com "Waiting for"
-- realmente visível — ignora UIs fantasmas/residuais.
-- Loop a 0.15s. Zero HttpGet — usa dados já na memória (pre-load).
-- ============================================================

-- Verifica se um GuiObject está REALMENTE visível (checa todos os ancestrais)
local function isTrulyVisible(object)
    if not object or not object:IsA("GuiObject") then return false end
    if not object.Visible then return false end
    if object:IsA("TextLabel") and (object.TextTransparency >= 1 or object.Text == "") then return false end
    local current = object.Parent
    while current do
        if current:IsA("GuiObject") then
            if not current.Visible then return false end
        elseif current:IsA("ScreenGui") then
            if not current.Enabled then return false end
            break
        else
            break
        end
        current = current.Parent
    end
    return true
end

-- Retorna a ScreenGui exata que está mostrando o loading real agora
local function obterScreenGuiDoLoadingAtivo()
    local pg = player:FindFirstChild("PlayerGui")
    if not pg then return nil end
    for _, v in ipairs(pg:GetDescendants()) do
        if v:IsA("TextLabel") and v.Text and v.Text:find("Waiting for") then
            if isTrulyVisible(v) then
                return v:FindFirstAncestorOfClass("ScreenGui")
            end
        end
    end
    return nil
end

-- Extrai o nome do mapa do padrão "#1: Nome [Dificuldade]"
local function extrairNomeMapa(texto)
    local nome = texto:match("#%d+:%s*([^%[%]]+)%s*%[")
    if nome then
        return nome:match("^%s*(.-)%s*$")
    end
    return nil
end

-- Loop principal do Detector V17.0
task.spawn(function()
    while true do
        task.wait(0.15)
        if not state.autoPlayEnabled then continue end

        -- 1. Busca a ScreenGui de loading real
        local guiAtiva = obterScreenGuiDoLoadingAtivo()
        if not guiAtiva then continue end

        -- 2. Extrai o nome do mapa SOMENTE de dentro da guiAtiva
        local mapaAtual = nil
        for _, v in ipairs(guiAtiva:GetDescendants()) do
            if v:IsA("TextLabel") and v.Text and isTrulyVisible(v) then
                local nome = extrairNomeMapa(v.Text)
                if nome and nome ~= "" then
                    mapaAtual = nome
                    break
                end
            end
        end
        if not mapaAtual then continue end

        -- 3. Ignora se já processamos este mapa
        if mapaAtual == state.ultimoMapaDetectado then continue end
        state.ultimoMapaDetectado = mapaAtual

        -- 4. Remove espaços: "Lost Woods" → "LostWoods"
        local mapaFormatado = mapaAtual:gsub("%s+", "")

        -- 5. Busca keyframes na memória LOCAL — 0ms, zero HttpGet
        local keyframes = savedTAS[mapaFormatado]
        if not keyframes or #keyframes == 0 then
            -- Alteração 4: mensagem clara orientando o usuário
            showNotif("⚠️ Mapa não baixado! Vá na aba TAS Files e atualize a lista.", false, 4)
            print("[Detector V17] Mapa sem keyframes locais: " .. mapaFormatado)
            continue
        end

        state.currentTAS     = keyframes
        state.currentMapName = mapaFormatado

        -- 6. Notificação imediata com contagem de keyframes
        showNotif("🎯 Mapa: " .. mapaAtual .. " | KF: " .. #keyframes, true, 4)
        print("[Detector V17] Detectado: " .. mapaAtual .. " — " .. #keyframes .. " eventos")

        -- 7. Aguarda o loading sumir monitorando a guiAtiva (timeout 90s)
        local timeout = 0
        while timeout < 600 do
            task.wait(0.15)
            timeout = timeout + 1
            -- Verifica se a guiAtiva ainda está ativa
            local ainda_ativa = false
            pcall(function()
                ainda_ativa = guiAtiva.Parent ~= nil and guiAtiva.Enabled
                    and obterScreenGuiDoLoadingAtivo() == guiAtiva
            end)
            if not ainda_ativa then break end
        end

        -- 8. Pausa de segurança para spawn do personagem
        task.wait(0.6)

        -- 9. Dispara o TAS automaticamente
        if state.autoPlayEnabled and #state.currentTAS > 0 then
            showNotif("🤖 Executando TAS: " .. mapaAtual, true, 2)
            startPlayback()
        end
    end
end)

