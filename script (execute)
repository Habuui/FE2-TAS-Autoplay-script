-- ========== TECLAS DE ATALHO ==========
local inputConnection
inputConnection = uis.InputBegan:Connect(function(input, gpe)
    if isTyping() then return end
    if input.KeyCode == Enum.KeyCode.G then
        if state.isRecording then stopRecording() else startRecording() end
    elseif input.KeyCode == Enum.KeyCode.R then
        if state.isPlaying then interruptPlayback()
        elseif not state.isRecording then startPlayback() end
    elseif input.KeyCode == Enum.KeyCode.N then
        toggleMinimize()
    elseif input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        fakeWallclip()
    elseif input.KeyCode == Enum.KeyCode.Space then
        fakeWallhop()
    end
end)

-- Botão Parar Script: desconecta tudo e destrói a GUI completamente.
-- O jogador executa o script pelo executor novamente para reabrir.
stopScriptBtn.MouseButton1Click:Connect(function()
    if state.recordingConnection then
        for _, conn in ipairs(state.recordingConnection) do
            if conn then pcall(function() conn:Disconnect() end) end
        end
    end
    if state.playbackConnection then
        pcall(function() state.playbackConnection:Disconnect() end)
    end
    if inputConnection then
        pcall(function() inputConnection:Disconnect() end)
    end
    sg:Destroy()
end)

