local refreshSavedList

-- ========== SALVAR / DELETAR TAS Local ==========
local function saveTAS(name)
    if #state.currentTAS < 10 then
        showNotif("❌ Poucos frames para salvar!", false)
        return false
    end
    if name == nil or name == "" then name = "TAS_" .. os.time() end

    local finalName = name
    local counter   = 1
    while savedTAS[finalName] do
        finalName = name .. "_" .. counter
        counter   = counter + 1
    end

    savedTAS[finalName]       = state.currentTAS
    getgenv().FE2_TAS_SAVES   = savedTAS
    showNotif("💾 Salvo localmente: " .. finalName, true)
    refreshSavedList()
    return true
end

local function deleteTAS(name)
    if savedTAS[name] then
        savedTAS[name]          = nil
        getgenv().FE2_TAS_SAVES = savedTAS
        showNotif("🗑️ Deletado: " .. name, true)
        refreshSavedList()
    end
end

-- ========== GRAVAÇÃO ==========
local recordingStartTime = 0
local inputConnections   = nil

local function startRecording()
    if state.isRecording then showNotif("❌ Já gravando!", false); return end
    if state.isPlaying then
        state.isPlaying = false
        if state.playbackConnection then
            state.playbackConnection:Disconnect()
            state.playbackConnection = nil
        end
    end

    state.currentTAS     = {}
    state.currentMapName = ""
    state.isRecording    = true
    recordingStartTime   = tick()

    for k in pairs(state.lastInputStates) do state.lastInputStates[k] = false end
    showNotif("🔴 GRAVAÇÃO INICIADA! Pressione G para parar", true)

    local kfConn = rs.Stepped:Connect(function()
        if not state.isRecording then return end
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
            local hrp      = char.HumanoidRootPart
            local humanoid = char.Humanoid
            table.insert(state.currentTAS, {
                type         = "keyframe",
                time         = tick() - recordingStartTime,
                cframe       = hrp.CFrame,
                velocity     = hrp.Velocity,
                moveDirection= humanoid.MoveDirection,
                humanoidState= humanoid:GetState(),
                slideActive  = uis:IsKeyDown(Enum.KeyCode.E),
            })
        end
    end)

    local function onInputBegan(input, gpe)
        if not state.isRecording or gpe then return end
        for name, code in pairs(KEYS) do
            if input.KeyCode == code and not state.lastInputStates[name] then
                state.lastInputStates[name] = true
                table.insert(state.currentTAS, {
                    type  = "input",
                    time  = tick() - recordingStartTime,
                    key   = name,
                    state = true,
                })
            end
        end
    end

    local function onInputEnded(input, gpe)
        if not state.isRecording or gpe then return end
        for name, code in pairs(KEYS) do
            if input.KeyCode == code and state.lastInputStates[name] then
                state.lastInputStates[name] = false
                table.insert(state.currentTAS, {
                    type  = "input",
                    time  = tick() - recordingStartTime,
                    key   = name,
                    state = false,
                })
            end
        end
    end

    local ibConn = uis.InputBegan:Connect(onInputBegan)
    local ieConn = uis.InputEnded:Connect(onInputEnded)
    inputConnections      = {kfConn, ibConn, ieConn}
    state.recordingConnection = inputConnections
end

local function stopRecording()
    if not state.isRecording then return end
    state.isRecording = false
    if state.recordingConnection then
        for _, conn in ipairs(state.recordingConnection) do
            if conn then pcall(function() conn:Disconnect() end) end
        end
        state.recordingConnection = nil
    end
    table.sort(state.currentTAS, function(a, b) return a.time < b.time end)
    if #state.currentTAS > 10 then
        showNotif("⏹️ Gravação concluída! (" .. #state.currentTAS .. " eventos)", true)
    else
        showNotif("⚠️ Poucos eventos gravados!", false)
        state.currentTAS = {}
    end
end

-- ========== RESTAURAR CONTROLE ==========
local function restoreCharacterControl()
    if state.isPlaying then
        state.isPlaying = false
        if state.playbackConnection then
            pcall(function() state.playbackConnection:Disconnect() end)
            state.playbackConnection = nil
        end
    end
    for _, code in pairs(KEYS) do
        pcall(function() vim:SendKeyEvent(false, code, false, game) end)
    end
    local char = player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = DEFAULT_WALK_SPEED
            humanoid.JumpPower = DEFAULT_JUMP_POWER
            humanoid.AutoRotate = true
        end
        if state.originalRootC0 then
            local rj = char:FindFirstChild("RootJoint", true)
            if rj then pcall(function() rj.C0 = state.originalRootC0 end) end
            state.originalRootC0 = nil
        end
    end
end

local function interruptPlayback()
    if not state.isPlaying then return end
    state.isPlaying = false
    if state.playbackConnection then
        pcall(function() state.playbackConnection:Disconnect() end)
        state.playbackConnection = nil
    end
    restoreCharacterControl()
    showNotif("⏹️ Reprodução cancelada!", false, 2)
end

-- ========== REPRODUÇÃO HÍBRIDA ==========
local function startPlayback()
    local now = tick()
    if now - state.lastPlaybackCall < 0.5 then return end
    state.lastPlaybackCall = now

    if #state.currentTAS == 0 then showNotif("❌ Nenhum TAS carregado!", false); return end
    if state.isPlaying then interruptPlayback(); task.wait(0.05) end

    local char = player.Character
    if not char then return end
    local hrp      = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end

    state.originalWalkSpeed = humanoid.WalkSpeed
    state.originalJumpPower = humanoid.JumpPower
    humanoid.WalkSpeed = DEFAULT_WALK_SPEED
    humanoid.JumpPower = DEFAULT_JUMP_POWER
    humanoid.AutoRotate = false

    local rootJoint = char:FindFirstChild("RootJoint", true)
    if rootJoint then state.originalRootC0 = rootJoint.C0 else state.originalRootC0 = nil end

    local firstKF = nil
    for _, ev in ipairs(state.currentTAS) do
        if ev.type == "keyframe" then firstKF = ev; break end
    end
    if firstKF and firstKF.cframe then
        hrp.CFrame   = firstKF.cframe
        hrp.Velocity = Vector3.zero
    end

    task.wait(0.1)

    char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") then
        restoreCharacterControl(); return
    end

    state.isPlaying        = true
    state.playbackStartTime= tick()
    local eventIndex       = 1
    local totalEvents      = #state.currentTAS
    local lastSlideState   = false
    local lastApplied      = {}
    for k in pairs(KEYS) do lastApplied[k] = false end
    local wallhopProcessed = false
    local isFlicking       = false

    showNotif("▶️ REPRODUZINDO...", true)

    state.playbackConnection = rs.Stepped:Connect(function()
        if not state.isPlaying then return end
        local cc = player.Character
        if not cc or not cc:FindFirstChild("HumanoidRootPart") or not cc:FindFirstChild("Humanoid") then
            restoreCharacterControl()
            showNotif("❌ Personagem interrompido.", false)
            return
        end
        local ch    = cc.HumanoidRootPart
        local hum   = cc.Humanoid
        local elapsed = tick() - state.playbackStartTime

        while eventIndex <= totalEvents and state.currentTAS[eventIndex].time <= elapsed do
            local ev = state.currentTAS[eventIndex]

            if ev.type == "keyframe" then
                if ev.cframe   then ch.CFrame   = ev.cframe end
                if ev.velocity then
                    ch.Velocity             = ev.velocity
                    ch.AssemblyLinearVelocity = ev.velocity
                end
                
                if ev.humanoidState then
                    local currentEnum = hum:GetState()
                    local isDifferent = false
                    if type(ev.humanoidState) == "number" then
                        isDifferent = (currentEnum.Value ~= ev.humanoidState)
                    else
                        isDifferent = (currentEnum ~= ev.humanoidState)
                    end
                    if isDifferent then
                        hum:ChangeState(ev.humanoidState)
                    end
                end

                if hum.WalkSpeed ~= DEFAULT_WALK_SPEED then hum.WalkSpeed = DEFAULT_WALK_SPEED end

                if ev.slideActive ~= nil and ev.slideActive ~= lastSlideState then
                    lastSlideState = ev.slideActive
                    vim:SendKeyEvent(ev.slideActive, Enum.KeyCode.E, false, game)
                end

                if state.wallhopEnabled and ev.wallhopFlick and not wallhopProcessed and not isFlicking then
                    wallhopProcessed = true
                    isFlicking       = true
                    task.spawn(function()
                        if hum and hum.Parent then
                            hum:ChangeState(Enum.HumanoidStateType.Jumping)
                            task.wait(0.05)
                            ch.Velocity = Vector3.new(ch.Velocity.X, 40, ch.Velocity.Z)
                            local rj = cc:FindFirstChild("RootJoint", true)
                            if rj and state.originalRootC0 then
                                local orig = state.originalRootC0
                                pcall(function() rj.C0 = orig * CFrame.Angles(0, 0, math.rad(65)) end)
                                task.wait(0.08)
                                pcall(function() if rj and rj.Parent then rj.C0 = orig end end)
                            end
                        end
                        isFlicking = false
                    end)
                elseif not ev.wallhopFlick then
                    wallhopProcessed = false
                end

            elseif ev.type == "input" then
                local keyCode = KEYS[ev.key]
                if keyCode and lastApplied[ev.key] ~= ev.state then
                    lastApplied[ev.key] = ev.state
                    pcall(function() vim:SendKeyEvent(ev.state, keyCode, false, game) end)
                end
            end

            eventIndex = eventIndex + 1
        end

        if eventIndex > totalEvents then
            for key, code in pairs(KEYS) do
                if lastApplied[key] then
                    pcall(function() vim:SendKeyEvent(false, code, false, game) end)
                end
            end
            if lastSlideState then vim:SendKeyEvent(false, Enum.KeyCode.E, false, game) end

            state.isPlaying = false
            if state.playbackConnection then
                state.playbackConnection:Disconnect()
                state.playbackConnection = nil
            end
            restoreCharacterControl()
            showNotif("✅ REPRODUÇÃO FINALIZADA!", true, 2.5)
        end
    end)
end

-- ========== RESET ==========
local function forceReset()
    if state.isRecording then stopRecording() end
    if state.isPlaying    then interruptPlayback() end
    state.currentTAS     = {}
    state.currentMapName = ""
    showNotif("🔄 Estado limpo!", true, 1.5)
end

-- ========== WALLCLIP ==========
local function fakeWallclip()
    if not state.wallclipEnabled then return end
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char}

    local ray = workspace:Raycast(hrp.Position, hrp.CFrame.LookVector * 2.5, params)
    if ray and ray.Distance < 2.2 then
        hrp.CFrame = CFrame.new(hrp.Position + hrp.CFrame.LookVector * 5)
        showNotif("🌀 WALLCLIP!", true, 0.8)
    end
end

-- ========== WALLHOP MANUAL ==========
local function fakeWallhop()
    if not state.wallhopEnabled then return end
    local char = player.Character
    if not char then return end
    local hrp      = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char}

    local ray = workspace:Raycast(hrp.Position, hrp.CFrame.LookVector * 2, params)
    if ray and ray.Distance < 1.8 then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        task.wait(0.05)
        hrp.Velocity = Vector3.new(hrp.Velocity.X, 40, hrp.Velocity.Z)
        if state.isRecording and #state.currentTAS > 0 then
            for i = #state.currentTAS, 1, -1 do
                if state.currentTAS[i].type == "keyframe" then
                    state.currentTAS[i].wallhopFlick = true
                    break
                end
            end
        end
        task.spawn(function()
            local rj = char:FindFirstChild("RootJoint", true)
            if rj then
                local orig = rj.C0
                pcall(function() rj.C0 = orig * CFrame.Angles(0, 0, math.rad(65)) end)
                task.wait(0.08)
                pcall(function() if rj and rj.Parent then rj.C0 = orig end end)
            end
        end)
        showNotif("🚀 WALLHOP!", true, 0.8)
    end
end

-- ========== EXPORTAÇÃO CORRIGIDA ==========
local function serializeVector3(v)
    return string.format("Vector3.new(%f, %f, %f)", v.X, v.Y, v.Z)
end

local function serializeCFrame(cf)
    return string.format("CFrame.new(%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f)", cf:GetComponents())
end

local function exportCurrentTAS(mapName)
    if not state.currentTAS or #state.currentTAS == 0 then
        showNotif("❌ Nenhum TAS na memória para exportar!", false, 2)
        return
    end
    if not mapName or mapName == "" then mapName = "mapa_desconhecido" end
    local lines = {}
    table.insert(lines, "    if mapName == \"" .. mapName .. "\" then")
    table.insert(lines, "        tasData = {")
    for _, ev in ipairs(state.currentTAS) do
        if ev.type == "keyframe" then
            local cfStr = serializeCFrame(ev.cframe)
            local velStr = serializeVector3(ev.velocity)
            local slideStr = tostring(ev.slideActive or false)
            local flickStr = tostring(ev.wallhopFlick or false)
            local hStateStr = ev.humanoidState and tostring(ev.humanoidState.Value) or "Enum.HumanoidStateType.Running.Value"
            local kfLine = string.format('            {type="keyframe",time=%f,cframe=%s,velocity=%s,slideActive=%s,wallhopFlick=%s,humanoidState=%s},', ev.time, cfStr, velStr, slideStr, flickStr, hStateStr)
            table.insert(lines, kfLine)
        elseif ev.type == "input" then
            local inputLine = string.format('            {type="input",time=%f,key="%s",state=%s},', ev.time, ev.key, tostring(ev.state))
            table.insert(lines, inputLine)
        end
    end
    table.insert(lines, "        }")
    table.insert(lines, "    end")
    local output = table.concat(lines, "\n")
    local copied = false
    if setclipboard then
        pcall(function() setclipboard(output); copied = true end)
    elseif toclipboard then
        pcall(function() toclipboard(output); copied = true end)
    end
    if copied then
        showNotif("📤 Bloco do mapa copiado! Pronto para colar no library.lua", true, 3)
    else
        print("\n=== COPIE O TEXTO ABAIXO PARA O SEU LIBRARY.LUA ===\n")
        print(output)
        print("\n==================================================\n")
        showNotif("⚠️ setclipboard não suportado! Bloco impresso no F9.", false, 4)
    end
end

-- ========== CARREGAR LIBRARY.LUA DO GITHUB ==========
local loadedLibrary = nil
local availableMaps = {}
local refreshGitList

local function extractMapNamesFromCode(code)
    local maps = {}
    for name in code:gmatch('mapName%s*==%s*"([^"]+)"') do
        table.insert(maps, name)
    end
    return maps
end

local function loadLibraryFromGitHub()
    showNotif("⏳ Baixando library.lua do GitHub...", true, 2)
    task.spawn(function()
        local ok, code = pcall(function() return game:HttpGet(LIBRARY_URL, true) end)
        if not ok or not code or code == "" then
            showNotif("❌ Falha ao acessar o GitHub. Verifique a URL.", false, 3)
            return
        end
        availableMaps = extractMapNamesFromCode(code)
        local execOk, lib = pcall(function() return loadstring(code)() end)
        if execOk and type(lib) == "table" then
            loadedLibrary = lib
            showNotif("✅ Library carregada! " .. #availableMaps .. " mapa(s) disponível(is).", true, 2.5)
        else
            loadedLibrary = nil
            showNotif("⚠️ " .. #availableMaps .. " mapa(s) encontrado(s) (somente leitura).", true, 2.5)
        end
        refreshGitList()
    end)
end

