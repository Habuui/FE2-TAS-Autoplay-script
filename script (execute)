-- ========== AUXILIARES VISUAIS ==========
local function addStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color
    stroke.Thickness = thickness
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = parent
    return stroke
end

local function applyShineStroke(instance, strokeColor, shineColor)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.5
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = instance

    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   strokeColor),
        ColorSequenceKeypoint.new(0.4, strokeColor),
        ColorSequenceKeypoint.new(0.5, shineColor),
        ColorSequenceKeypoint.new(0.6, strokeColor),
        ColorSequenceKeypoint.new(1,   strokeColor),
    })
    gradient.Parent = stroke

    task.spawn(function()
        while instance and instance.Parent do
            gradient.Rotation = 0
            local tween = ts:Create(gradient, TweenInfo.new(2.5, Enum.EasingStyle.Linear), {Rotation = 360})
            tween:Play()
            tween.Completed:Wait()
        end
    end)
    return stroke
end

local function addHoverEffect(btn, normalCol, hoverCol)
    btn.MouseEnter:Connect(function()  btn.BackgroundColor3 = hoverCol  end)
    btn.MouseLeave:Connect(function()  btn.BackgroundColor3 = normalCol end)
end

