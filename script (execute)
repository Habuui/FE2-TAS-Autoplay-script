    end

    if #availableMaps == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 40)
        empty.BackgroundTransparency = 1
        empty.Text = "Nenhum arquivo .lua encontrado na pasta keyframes."
        empty.TextColor3 = Color3.fromRGB(130, 130, 150)
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.Parent = gitScroll
        gitScroll.CanvasSize = UDim2.new(0, 0, 0, 45)
        return
    end

    for _, mapName in ipairs(availableMaps) do
        local item = Instance.new("Frame")
        item.Size = UDim2.new(1, 0, 0, 40)
        item.BackgroundColor3 = Color3.fromRGB(20, 26, 35)
        item.BorderSizePixel = 0
        item.Parent = gitScroll
        Instance.new("UICorner", item).CornerRadius = UDim.new(0, 6)

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.65, 0, 1, 0)
        lbl.Position = UDim2.new(0, 8, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = "🗺️ " .. mapName
        lbl.TextColor3 = Color3.fromRGB(200, 220, 255)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 10
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = item

        local loadB = Instance.new("TextButton")
        loadB.Size = UDim2.new(0.25, 0, 0.8, 0)
        loadB.Position = UDim2.new(0.72, 0, 0.1, 0)
        loadB.BackgroundColor3 = Color3.fromRGB(0, 120, 150)
        loadB.Text = "Carregar"
        loadB.TextColor3 = Color3.fromRGB(255, 255, 255)
        loadB.Font = Enum.Font.GothamBold
        loadB.TextSize = 9
        loadB.Parent = item
        Instance.new("UICorner", loadB).CornerRadius = UDim.new(0, 4)
        addHoverEffect(loadB, Color3.fromRGB(0, 120, 150), Color3.fromRGB(0, 160, 200))

        local capMap = mapName
        loadB.MouseButton1Click:Connect(function()
            -- Verifica primeiro na memória local (pre-load)
            local localData = savedTAS[capMap]
            if localData and #localData > 0 then
                state.currentTAS     = localData
                state.currentMapName = capMap
                showNotif("📂 Carregado da memória: " .. capMap, true)
                return
            end
            -- Fallback: baixa do GitHub se não estiver em cache
            local url = KEYFRAMES_BASE_URL .. capMap .. ".lua"
            showNotif("⏳ Baixando " .. capMap .. "...", true, 1.5)
            task.spawn(function()
                local ok, code = pcall(function() return game:HttpGet(url, true) end)
                if not ok or not code then
                    showNotif("❌ Falha ao baixar o mapa: " .. capMap, false, 2)
                    return
                end
                local func, err = loadstring(code)
                if not func then
                    showNotif("❌ Erro no arquivo: " .. tostring(err), false, 2)
                    return
                end
                local tasData = func()
                if type(tasData) == "table" and #tasData > 0 then
                    savedTAS[capMap]        = tasData
                    getgenv().FE2_TAS_SAVES = savedTAS
                    state.currentTAS     = tasData
                    state.currentMapName = capMap
                    refreshSavedList()
                    showNotif("📥 Carregado do GitHub: " .. capMap, true)
                else
                    showNotif("❌ Dados inválidos no arquivo.", false, 2)
                end
            end)
        end)
    end
    gitScroll.CanvasSize = UDim2.new(0, 0, 0, #availableMaps * 45)
end

